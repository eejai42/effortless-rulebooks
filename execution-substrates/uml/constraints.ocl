-- Table: HumanAgents
context HumanAgents

-- Count of roles currently filled by this agent.
-- Formula for CountOfRoles - parse error: Unexpected character '!' at position 14
-- Original: =COUNTIFS(Roles!{{FilledBy}}, HumanAgents!{{HumanAgentId}})

-- Table: Roles
