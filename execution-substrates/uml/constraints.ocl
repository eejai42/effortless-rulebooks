-- Original: =INDEX(Roles!{{Label}}, MATCH(WorkflowSteps!{{AssignedRole}}, Roles!{{RoleId}}, 0))

-- Denormalized lookup of assigned role comment/description.
-- Formula for AssignedRoleComment - parse error: Unexpected character '!' at position 11
-- Original: =INDEX(Roles!{{Comment}}, MATCH(WorkflowSteps!{{AssignedRole}}, Roles!{{RoleId}}, 0))

-- Denormalized lookup of agent currently filling the assigned role.
-- Formula for AssignedRoleFilledBy - parse error: Unexpected character '!' at position 11
-- Original: =INDEX(Roles!{{FilledBy}}, MATCH(WorkflowSteps!{{AssignedRole}}, Roles!{{RoleId}}, 0))

-- Table: Workflows
context Workflows

-- Count of steps in this workflow. Aggregation over IsStepOf relationship.
-- Formula for CountOfWorkflowSteps - parse error: Unexpected character '!' at position 22
