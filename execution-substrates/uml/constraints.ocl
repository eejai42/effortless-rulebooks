-- Formula for Label_from_DelegatesTo - parse error: Unexpected character '!' at position 11
-- Original: =INDEX(Roles!{{Label}}, MATCH(Roles!{{DelegatesTo}}, Roles!{{RoleId}}, 0))

-- Denormalized lookup of agent name (foaf:name) filling this role.
-- Formula for FilledByName - parse error: Unexpected character '!' at position 17
-- Original: =INDEX(HumanAgents!{{Name}}, MATCH(Roles!{{FilledBy}}, HumanAgents!{{HumanAgentId}}, 0))

-- Denormalized lookup of agent email (foaf:mbox) filling this role.
-- Formula for FilledByMBox - parse error: Unexpected character '!' at position 17
-- Original: =INDEX(HumanAgents!{{Mbox}}, MATCH(Roles!{{FilledBy}}, HumanAgents!{{HumanAgentId}}, 0))

-- Table: WorkflowSteps
context WorkflowSteps

-- Denormalized lookup of parent workflow title.
-- Formula for IsStepOfTitle - parse error: Unexpected character '!' at position 15
